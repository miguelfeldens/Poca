# Database (Cloud SQL or local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/poca

# Google OAuth 2.0
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Gemini AI
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Security
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# App
INVITE_PASSPHRASE=your-secret-invite-passphrase
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
